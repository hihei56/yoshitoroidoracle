# =============================================
# .env — Oracle Cloud 設定
# =============================================

# ▼ Oracle必須：データ保存先（事前に mkdir -p で作成しておく）
DATA_DIR=/home/ubuntu/botdata

# ▼ Discord
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# ▼ OpenAI（moderator.jsのテキスト検閲用・無料）
OPENAI_API_KEY=

# ▼ Groq（rssBot.js AI返信 / scheduler.js ニュース解説 / ranking.js コメント / yoshiyoshi.js フォールバック）
GROQ_API_KEY=

# ▼ Ollama（yoshiyoshi.js 全肯定返信のプライマリ・ローカル無料）
# VPS等に事前セットアップが必要:
#   curl -fsSL https://ollama.com/install.sh | sh
#   ollama pull qwen2.5:3b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ▼ YouTube / Twitch（ranking.js）
YOUTUBE_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ▼ Webhook URLs
RANKING_WEBHOOK_URL=
UNTAI_WEBHOOK=
AI_WEBHOOK1=
AI_WEBHOOK2=
AI_WEBHOOK3=

# ▼ チャンネルID
RANKING_CHANNEL_ID=
EDIT_LOG_CHANNEL_ID=

# ▼ デバッグモード（ランキング手動実行・scheduler起動時テスト投稿を有効化）
DEBUG_MODE=false
