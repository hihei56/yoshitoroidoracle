# =============================================
# .env — Oracle Cloud 設定
# =============================================

# ▼ Oracle必須：データ保存先（事前に mkdir -p で作成しておく）
DATA_DIR=/home/ubuntu/botdata

# ▼ Discord
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# ▼ OpenAI（moderator.jsのテキスト検閲用・無料）
OPENAI_API_KEY=

# ▼ Groq（rssBot.js AI返信 / scheduler.js ニュース解説 / ranking.js コメント）
GROQ_API_KEY=
# ※ RSS投稿先チャンネルは /admin rss_channel で設定（Webhookはbotが自動作成）

# ▼ Cloudflare Workers AI（chatter.js の雑談生成用。設定するとAuto時のローテーション対象に加わる）
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ▼ Gemini（chatter.js の雑談生成用。設定するとAuto時のローテーション対象に加わる）
# https://aistudio.google.com/apikey で無料取得可能
GEMINI_API_KEY=
# ※ chatter.jsのAIプロバイダーは既定でAuto（Groq/Cloudflare/Geminiのうち鍵設定済みかつ
#   無料枠が残っているものをランダムに使い分け）。/admin2 chatter_ai provider: で固定も可能

# ▼ YouTube / Twitch（ranking.js）
YOUTUBE_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ▼ Webhook URLs
RANKING_WEBHOOK_URL=
AI_WEBHOOK1=
AI_WEBHOOK2=
AI_WEBHOOK3=

# ▼ チャンネルID
RANKING_CHANNEL_ID=
EDIT_LOG_CHANNEL_ID=

# ▼ デバッグモード（ランキング手動実行・scheduler起動時テスト投稿を有効化）
DEBUG_MODE=false
